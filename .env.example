# ── Airflow core ──────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false

# Generate with:
# python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here

# ── Airflow metadata database ─────────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ── Pipeline database ─────────────────────────────────────────────────────────
PIPELINE_DB_USER=pipeline
PIPELINE_DB_PASSWORD=pipeline123
PIPELINE_DB_NAME=nyc_taxi
PIPELINE_DB_HOST=pipeline_db
PIPELINE_DB_PORT=5432

# ── Data paths ────────────────────────────────────────────────────────────────
# Local folder where downloaded parquet files are stored
DATA_DIR=/opt/airflow/data

# NYC TLC data base URL
TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data
